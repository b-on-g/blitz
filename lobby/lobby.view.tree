$bog_blitz_lobby $mol_page
	Head null
	body /
		<= Qr $bog_qr
			uri <= qr_data \
			error_correction \M
			center /
				<= Logo $mol_image
					uri \bog/blitz/assets/logo.svg
			module_radius 0.35
			finder_radius 1.2
			gradient_angle 185
			gradient_stops /
				\var(--mol_theme_special)
				\var(--mol_theme_focus)
		<= Join $mol_button_major
			title \Войти
			click? <=> join? null
		<= Players $mol_view
			sub <= player_rows /
	Player* $mol_view
		sub /
			<= player_name* \
