$bog_blitz_lobby_game $mol_view
	quiz_data null
	game_state \
	current_question_text \
	state_reading @ \Read the question
	state_answering @ \Time to answer!
	state_leaderboard @ \Leaderboard
	state_final @ \Final Results
	state_label \
	sub /
		<= State $mol_paragraph
			title <= state_label
		<= Question $mol_paragraph
			title <= current_question_text
