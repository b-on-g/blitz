$bog_blitz $mol_page
	title @ \Giper Blitz Quiz
	tools /
		<= Navbar $mol_switch
			value? <=> screen? \lobby
			dictionary *string
				lobby \Lobby
				game \Game
				admin \Admin
		<= Theme_toggle $bog_theme_toggle
			theme_auto <= Theme
	plugins /
		<= Theme $bog_theme_auto
			theme_light \$mol_theme_light
			theme_dark \$mol_theme_dark
			themes /
				\$mol_theme_calm_light
				\$mol_theme_calm_dark
	body <= screen_body /
