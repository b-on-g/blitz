$bog_blitz_blog_menu $mol_page
	title \Блог
	body /
		<= Logo $mol_image
			uri \bog/blitz/assets/logo.svg
		<= Heading $mol_paragraph
			title \Giper Blitz Quiz
		<= Subtitle $mol_paragraph
			title \Реалтайм квизы для митапов и мероприятий
		<= Nav $mol_list
			rows <= nav_rows /
	Link*0 $mol_link
		arg *
			page <= link_slug*0 \
		title <= link_title*0 \
